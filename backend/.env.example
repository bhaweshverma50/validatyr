# Validatyr Backend Environment Variables

# Supabase Configuration
# Go to https://supabase.com/dashboard/project/_/settings/api to find your URL and Key
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Firebase Push Configuration
# 1. Create a service account: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# 2. Save JSON to backend/firebase-service-account.json (already gitignored)
# 3. Set ONE of the following:
FIREBASE_PROJECT_ID=your_firebase_project_id
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Frontend Firebase config (not committed — generate locally):
#   cd frontend && flutterfire configure --project=your_firebase_project_id
# This creates: firebase_options.dart, google-services.json, GoogleService-Info.plist

# Scheduling
# Set to "true" on Cloud Run to disable in-process APScheduler (use /cron-trigger instead)
# CLOUD_SCHEDULER_ENABLED=true
# Secret for authenticating Cloud Scheduler requests to /cron-trigger
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the same value in Cloud Scheduler's X-Cron-Secret header
# CRON_TRIGGER_SECRET=your_random_secret_here

# AI Providers
GEMINI_API_KEY=your_google_gemini_api_key
# CLAUDE_API_KEY=your_anthropic_api_key (Optional: for future Claude integration)
# OPENAI_API_KEY=your_openai_api_key (Optional: for future GPT/Whisper integration)
